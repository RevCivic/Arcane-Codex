# ─────────────────────────────────────────────────────
# Arcane Codex — environment variable reference
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────

# Port on the HOST machine that Docker Compose maps to the app's internal
# port 3000.  Change this if 3000 is already in use on your machine.
HOST_PORT=3000

# SQLite database URL used by the application at runtime.
# In Docker Compose this is set automatically; only override it here if you
# are running the app outside of Docker.
# DATABASE_URL=file:./prisma/dev.db

# Google Sheets spreadsheet ID for character import/sync.
# This is the value between /d/ and /edit in the Google Sheets URL.
# The sheet must be publicly readable (Share → Anyone with the link → Viewer).
# Defaults to the official campaign character sheet if left unset.
GOOGLE_SHEET_ID=1OZ2WHyECHeO3yB-7nYhVbl7jq-VagGR0zh9Td75GJi0

# Google OAuth credentials for "Log in with Google".
# Create OAuth credentials in Google Cloud and register the following redirect URI:
#   <AUTH_URL>/api/auth/callback/google
# where AUTH_URL is the value you set below (e.g. http://hq.shank-home.net:3001).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth.js secret used to sign session tokens/cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL used by Auth.js to build callback/session URLs.
# *** IMPORTANT: set this to the exact origin that users browse to. ***
#   - Local dev:  http://localhost:3000
#   - Custom host: http://hq.shank-home.net:3001
# This MUST match the origin in your Google OAuth authorized redirect URI.
# It must be origin-only (scheme + host + port). Do NOT include a path.
# Leaving this as localhost when deploying on another host is the most common
# cause of "Unknown Action" errors from Auth.js.
AUTH_URL=http://localhost:3000

# Allow Auth.js to trust the host header forwarded by your runtime/proxy.
# Keep this as true when running behind Docker/reverse proxies you control.
AUTH_TRUST_HOST=true
