# ─────────────────────────────────────────────────────
# Arcane Codex — environment variable reference
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────

# Port on the HOST machine that Docker Compose maps to the app's internal
# port 3000.  Change this if 3000 is already in use on your machine.
HOST_PORT=3000

# SQLite database URL used by the application at runtime.
# In Docker Compose this is set automatically; only override it here if you
# are running the app outside of Docker.
# DATABASE_URL=file:./prisma/dev.db
