# ─────────────────────────────────────────────────────
# Arcane Codex — environment variable reference
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────

# Port on the HOST machine that Docker Compose maps to the app's internal
# port 3000.  Change this if 3000 is already in use on your machine.
HOST_PORT=3000

# PostgreSQL connection used by Prisma.
# Docker Compose sets DATABASE_URL automatically for the app container.
# For local non-Docker runs, uncomment and customize this value.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arcane_codex?schema=public

# Docker Compose Postgres defaults (safe to keep for local development).
POSTGRES_DB=arcane_codex
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional path to a legacy SQLite file for one-time migration into PostgreSQL.
# Used by: npm run db:migrate:sqlite-to-postgres
SQLITE_DATABASE_URL=file:./prisma/dev.db

# Google Sheets spreadsheet ID for character import/sync.
# This is the value between /d/ and /edit in the Google Sheets URL.
# The sheet must be publicly readable (Share → Anyone with the link → Viewer).
# Defaults to the official campaign character sheet if left unset.
GOOGLE_SHEET_ID=1OZ2WHyECHeO3yB-7nYhVbl7jq-VagGR0zh9Td75GJi0

# ── Google Service Account (required for DB → Sheet write-back only) ───────────
# Writing back to the Google Sheet requires a service account with Editor access.
#
# Option A — paste the full JSON credential file as a single-line JSON string:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"bot@...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
#
# Option B — provide the two key fields separately:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=bot@my-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n
#
# Setup steps:
#   1. In Google Cloud Console, create a Service Account and download the JSON key.
#   2. Share the Google Sheet with the service account email as an Editor.
#   3. Set either GOOGLE_SERVICE_ACCOUNT_JSON or both individual vars above.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google OAuth credentials for "Log in with Google".
# Create OAuth credentials in Google Cloud and register the following redirect URI:
#   <AUTH_URL>/api/auth/callback/google
# where AUTH_URL is the value you set below (e.g. http://hq.shank-home.net:3001).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth.js secret used to sign session tokens/cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL used by Auth.js to build callback/session URLs.
# *** IMPORTANT: set this to the exact origin that users browse to. ***
#   - Local dev:  http://localhost:3000
#   - Custom host: http://hq.shank-home.net:3001
# This MUST match the origin in your Google OAuth authorized redirect URI.
# It must be origin-only (scheme + host + port). Do NOT include a path.
# Leaving this as localhost when deploying on another host is the most common
# cause of "Unknown Action" errors from Auth.js.
AUTH_URL=http://localhost:3000

# Allow Auth.js to trust the host header forwarded by your runtime/proxy.
# Keep this as true when running behind Docker/reverse proxies you control.
AUTH_TRUST_HOST=true

# AI service URL consumed by Next.js server actions.
# Default points to the compose `ai` service. For GPU profile, use http://ai-gpu:8000.
AI_SERVICE_URL=http://ai:8000

# AI mode controls which model profile is used.
# cpu = smaller/quantized default, gpu = larger/faster model profile.
AI_MODE=cpu

# AI backend/provider and model profile names.
AI_PROVIDER=local
AI_MODEL_CPU=codellama:7b-instruct-q4
AI_MODEL_GPU=mistral:7b-instruct

# Inference controls for text/stat generation suggestions.
AI_MAX_TOKENS=700
AI_TEMPERATURE=0.4

# Optional token for scheduled retraining endpoint:
# POST /api/admin/ai/retrain with header x-ai-retrain-token.
AI_RETRAIN_TOKEN=
