// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccessRole {
  USER
  ADMIN
}

enum AIGenerationType {
  CHARACTER_TEXT
  CHARACTER_STATS_SKILLS
  CHARACTER_BULK_TEXT
}

enum AIFeedbackStatus {
  ACCEPTED
  EDITED
  REJECTED
}

enum AITrainingJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model AllowedEmail {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  role      AccessRole @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  character Character?
  aiGenerations AIGeneration[]
  aiFeedback    AIFeedback[]
  aiTrainingJobs AITrainingJob[]
}

model Character {
  id              Int              @id @default(autoincrement())
  name            String
  firstName       String?
  lastName        String?
  race            String?
  gender          String?
  age             BigInt?
  role            String?
  description     String?
  stats           String?
  affiliation     String?
  currentCase     String?
  currentLocation String?
  homeOrigin      String?
  imageUrl        String?
  referenceLinks  Json?
  status          String?          @default("Active")
  claimedByEmail  String?          @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  claimedBy       AllowedEmail?    @relation(fields: [claimedByEmail], references: [email], onDelete: SetNull)
  tags            Tag[]
  sheet           CharacterSheet?
  characterPowers CharacterPower[]
  inventoryItems  InventoryItem[]
  events          Event[]
  rollHistory     RollHistory[]
  aiGenerations   AIGeneration[]
}

model Tag {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  characters Character[]
}

model CharacterSheet {
  id            Int                   @id @default(autoincrement())
  characterId   Int                   @unique
  character     Character             @relation(fields: [characterId], references: [id], onDelete: Cascade)
  // BRP Primary Characteristics
  str           Int?
  con           Int?
  siz           Int?
  dex           Int?
  intelligence  Int?
  pow           Int?
  cha           Int?
  app           Int?
  edu           Int?
  // Derived / current values
  currentHp     Int?
  maxHp         Int?
  currentSanity Int?
  maxSanity     Int?
  currentMp     Int?
  maxMp         Int?
  luck          Int?
  build         Int?
  // Free-text
  wounds        String?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  skillValues   CharacterSkillValue[]
}

/// Admin-managed skill definitions shared across all character sheets.
model Skill {
  id              Int                   @id @default(autoincrement())
  name            String                @unique
  category        String?
  baseValue       Int                   @default(0)
  description     String?
  sortOrder       Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  characterValues CharacterSkillValue[]
  rollHistory     RollHistory[]
}

/// A character's specific value for a skill.
model CharacterSkillValue {
  id                   Int            @id @default(autoincrement())
  sheetId              Int
  sheet                CharacterSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  skillId              Int
  skill                Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  value                Int
  /// Flagged true when a FAILURE or FUMBLE is rolled on this skill during a session.
  /// Cleared after the post-mission improvement roll is executed.
  markedForImprovement Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([sheetId, skillId])
}

model Place {
  id          Int      @id @default(autoincrement())
  name        String
  type        String?
  description String?
  region      String?
  imageUrl     String?
  coordinates  String?
  mapsLink     String?
  referenceLinks Json?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  effect      String?
  location    String?
  category    String?
  referenceLinks Json?
  carrierId   Int?
  carrier     Character? @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Event {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  date         String?
  significance String?
  outcome      String?
  referenceLinks Json?
  people       Character[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Power {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  description     String?
  effect          String?
  /// Free-text name of the ability roll associated with this power (e.g. "Telepathy").
  baseAbility     String?
  /// Base percentile skill value (1–100) for the ability roll. Null or 0 = passive / auto-success.
  basePercentage  Int?
  referenceLinks  Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  characterPowers CharacterPower[]
}

/// A character's assignment of a specific power, with an individual modifier.
model CharacterPower {
  id          Int               @id @default(autoincrement())
  characterId Int
  character   Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  powerId     Int
  power       Power             @relation(fields: [powerId], references: [id], onDelete: Cascade)
  /// Flat ±% modifier on top of power.basePercentage (positive = more proficient, negative = detriment).
  modifier    Int               @default(0)
  /// Optional free-text reason for the modifier, e.g. "split tongue −20 to verbal".
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  ability     CharacterAbility?

  @@unique([characterId, powerId])
}

/// A character-specific ability entry, tracking current proficiency and improvement marks.
/// Unlike Skills (which are global definitions), abilities are per-character and can be
/// freely added or removed by the DM. Power assignments automatically create/maintain
/// these entries when a power has a rollable ability.
model CharacterAbility {
  id                     Int             @id @default(autoincrement())
  characterId            Int
  character              Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  name                   String
  currentValue           Int
  /// Flagged true when a FAILURE or FUMBLE is rolled on this ability during a session.
  /// Cleared after the post-mission improvement roll is executed.
  markedForImprovement   Boolean         @default(false)
  /// Optional link to the CharacterPower whose baseAbility created this entry.
  /// Set to null when the ability outlives the power assignment.
  sourceCharacterPowerId Int?            @unique
  sourceCharacterPower   CharacterPower? @relation(fields: [sourceCharacterPowerId], references: [id], onDelete: SetNull)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  rollHistory            RollHistory[]

  @@unique([characterId, name])
}

/// Persisted roll records visible to the character owner and admins.
model RollHistory {
  id          Int               @id @default(autoincrement())
  characterId Int
  character   Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// 'ability' | 'skill' | 'power' | 'free'
  rollType    String
  /// Human-readable label, e.g. "STR Check", "Spot Hidden", "2d6+1"
  label       String
  /// The raw d100 result (or summed total for free rolls)
  roll        Int
  /// Effective target after difficulty modifier (null for free rolls)
  target      Int?
  /// Difficulty tier name (null for free rolls)
  difficulty  String?
  /// 'CRITICAL' | 'SUCCESS' | 'FAILURE' | 'FUMBLE' (null for free rolls)
  resultType  String?
  /// JSON-encoded number[] of individual die values (free rolls only)
  dice        String?
  /// Flat modifier added to free rolls
  modifier    Int?
  /// Luck points spent to convert this roll to a SUCCESS (null if none)
  luckSpent   Int?
  /// Skill linked to this roll (skill rolls only); used for improvement tracking
  skillId     Int?
  skill       Skill?            @relation(fields: [skillId], references: [id], onDelete: SetNull)
  /// CharacterAbility linked to this roll (power rolls only); used for improvement tracking
  abilityId   Int?
  ability     CharacterAbility? @relation(fields: [abilityId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
}

/// AI-generated suggestions before user acceptance/edit/reject.
model AIGeneration {
  id            String           @id @default(cuid())
  type          AIGenerationType
  createdByEmail String?
  createdBy     AllowedEmail?    @relation(fields: [createdByEmail], references: [email], onDelete: SetNull)
  characterId   Int?
  character     Character?       @relation(fields: [characterId], references: [id], onDelete: SetNull)
  modelName     String
  modelVersion  String?
  inputPayload  Json
  suggestion    Json
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  feedback      AIFeedback[]
}

/// Human feedback for trainable AI generation quality.
model AIFeedback {
  id             Int              @id @default(autoincrement())
  generationId   String
  generation     AIGeneration     @relation(fields: [generationId], references: [id], onDelete: Cascade)
  status         AIFeedbackStatus
  createdByEmail String?
  createdBy      AllowedEmail?    @relation(fields: [createdByEmail], references: [email], onDelete: SetNull)
  finalValues    Json?
  note           String?
  createdAt      DateTime         @default(now())
}

/// Persisted model snapshots for version tracking and rollback.
model AIModelVersion {
  id         Int      @id @default(autoincrement())
  modelName  String
  version    String   @unique
  mode       String
  metadata   Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

/// Requested AI retraining jobs (admin only).
model AITrainingJob {
  id              Int                 @id @default(autoincrement())
  requestedByEmail String?
  requestedBy     AllowedEmail?       @relation(fields: [requestedByEmail], references: [email], onDelete: SetNull)
  status          AITrainingJobStatus @default(PENDING)
  mode            String
  baseModel       String
  payload         Json?
  result          Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}
