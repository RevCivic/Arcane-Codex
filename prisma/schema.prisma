// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Character {
  id              Int             @id @default(autoincrement())
  name            String
  firstName       String?
  lastName        String?
  race            String?
  gender          String?
  age             Int?
  role            String?
  description     String?
  stats           String?
  affiliation     String?
  currentCase     String?
  currentLocation String?
  homeOrigin      String?
  status          String?         @default("Active")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  powers          Power[]
  inventoryItems  InventoryItem[]
  events          Event[]
}

model Place {
  id          Int      @id @default(autoincrement())
  name        String
  type        String?
  description String?
  region      String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  effect      String?
  location    String?
  category    String?
  carrierId   Int?
  carrier     Character? @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Event {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?
  date         String?
  significance String?
  outcome      String?
  people       Character[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Power {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  effect      String?
  personId    Int
  person      Character @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
