    },
    {
      "page": "/inventory/[id]/edit",
      "regex": "^/inventory/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/inventory/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
